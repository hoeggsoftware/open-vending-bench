# VendingBench Environment Configuration
# Copy this file to .env and fill in your actual keys

# Claude API key (for agent reasoning)
ANTHROPIC_API_KEY=your_claude_api_key_here

# Perplexity API key (for web search)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Cerebras API key (fast inference, ~2 sec/call, external API)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Buddy HPC API key (slower inference, ~23 sec/call, UCO HPC, no external costs)
BUDDY_API_KEY=your_buddy_api_key_here

# Model to use for supplier email generation (cerebras, buddy/GPT-OSS-120b, etc.)
SUPPLIER_MODEL=cerebras
